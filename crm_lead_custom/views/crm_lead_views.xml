<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_lead_view_form_custom" model="ir.ui.view">
        <field name="name">crm.lead.view.form.custom</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_all_leads"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='extra']" position="after">
                <page string="Custom" name="custom">
                    <group>
                        <field name="x_custom_notes"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
